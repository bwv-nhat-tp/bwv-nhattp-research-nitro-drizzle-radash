.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Environment files
.env
.env.*
!.env.example

# Whether you use PnP or not, the node_modules folder is often used to store
# build artifacts that should be gitignored
node_modules
**/node_modules

# Build output
dist
**/dist
.output
**/.output
build
**/build

# Framework and tool caches
.nitro
**/.nitro
.vite
**/.vite
.cache
**/.cache

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Swap the comments on the following lines if you wish to use zero-installs
# In that case, don't forget to run `yarn config set enableGlobalCache false`!
# Documentation here: https://yarnpkg.com/features/caching#zero-installs

#!.yarn/cache
.pnp.*

# This repo uses Yarn workspaces. Keep yarn.lock as the source of truth.
package-lock.json
pnpm-lock.yaml
